def generate_qa_pair(topic):
    messages = [
        {"role": "system", "content": "You generate question and answer pairs for training datasets. Give exactly one question and one answer."},
        {"role": "user", "content": f"Generate a Q&A pair about: {topic}"}
    ]
    input_ids = tokenizer.apply_chat_template(
        messages,
        return_tensors="pt"
    ).to("cuda")
    outputs = model.generate(input_ids, max_new_tokens=200)
    response = tokenizer.decode(outputs[0], skip_special_tokens=True)
    response = response.split("assistant")[-1].strip()
    return response



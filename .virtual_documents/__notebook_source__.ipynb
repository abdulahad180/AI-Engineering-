prompt_styles = [
    "Generate a Q&A pair about: {topic}",
    "Create a multiple choice question about: {topic}",
    "Write a short explanation with a follow-up question about: {topic}"
]


import random

def generate_diverse_qa(topic):
    prompt = random.choice(prompt_styles).format(topic=topic)
    messages = [
        {"role": "system", "content": "You generate training data. Give exactly one question and one answer."},
        {"role": "user", "content": prompt}
    ]
    input_ids = tokenizer.apply_chat_template(
        messages,
        return_tensors="pt"
    ).to("cuda")
    outputs = model.generate(input_ids, max_new_tokens=200)
    response = tokenizer.decode(outputs[0], skip_special_tokens=True)
    response = response.split("assistant")[-1].strip()
    return response


topics = ["machine learning", "deep learning", "neural networks"]

dataset = []
for topic in topics:
    for i in range(3):
        result = generate_diverse_qa(topic)
        dataset.append({"topic": topic, "text": result})
        display(Markdown(f"**{topic} — {i+1}/3**\n\n{result}"))


import gradio as gr
import json

def synthgen_ui(topic, num_examples):
    results = []
    for i in range(num_examples):
        result = generate_diverse_qa(topic)
        results.append(result)
    
    # JSONL file save karo
    filename = f"synthgen_{topic.replace(' ', '_')}.jsonl"
    with open(filename, "w") as f:
        for item in results:
            json.dump({"topic": topic, "text": item}, f)
            f.write("\n")
    
    # Markdown output
    output = "\n\n---\n\n".join(results)
    return output, filename

demo = gr.Interface(
    fn=synthgen_ui,
    inputs=[
        gr.Textbox(label="Topic", placeholder="e.g. Machine Learning"),
        gr.Slider(1, 10, value=3, step=1, label="Number of examples")
    ],
    outputs=[
        gr.Markdown(label="Generated Dataset"),
        gr.File(label="Download JSONL")
    ],
    title="SynthGen — Synthetic Dataset Generator",
    description="Generate synthetic training data using Llama 3.2 locally on GPU — No API needed!"
)

demo.launch(share=True)
